{
  "ipn_make_manifest": {
    "train_list": "datasets/ipnhand/annotations/Annot_TrainList.txt",
    "test_list": "datasets/ipnhand/annotations/Annot_TestList.txt",
    "out": "outputs/ipnhand/manifests/ipn_d0x_manifest",
    "labels": "D0X",
    "min_frames": 48,
    "chunk_frames": 96,
